<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.WishPort" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/accent</item>
        <item name="android:statusBarColor">@color/primary_dark</item>
        <item name="android:windowBackground">@color/bg_screen</item>
    </style>

    <!-- Tema para Splash Screen -->
    <style name="Theme.Splash" parent="Theme.MaterialComponents.NoActionBar">
        <item name="android:windowBackground">@drawable/logo</item>
        <item name="android:statusBarColor">@color/primary</item>
        <item name="android:windowFullscreen">false</item>
    </style>
</resources>

